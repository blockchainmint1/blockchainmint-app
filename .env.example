# Copy to .env and fill in real values. NEVER commit .env.
# ---------------------------------------------------------------------------
# PUBLIC (safe to ship in the client bundle — these are NOT secrets)
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT"

# Server-side mirror of the public values (used during SSR)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
SUPABASE_PROJECT_ID="YOUR_PROJECT"

# ---------------------------------------------------------------------------
# SECRET (server-only — host secret store, never in git, never VITE_-prefixed,
# never sent to the browser). On Lovable Cloud these are configured via the
# Secrets tool, not a .env file.
# ---------------------------------------------------------------------------
# Bypasses RLS. Treat like a root password.
SUPABASE_SERVICE_ROLE_KEY=""

# Cron auth secret is stored in Supabase Vault as `cron_webhook_secret`,
# not an env var. pg_cron reads it inline; the server reads it via the
# service-role client. No env value needed here.

# Upstream provider keys (billed to you — rate-limit endpoints that use them)
ALCHEMY_API=""
CMC_API=""

# TEXITcoin Omni RPC (basic auth)
TXC_RPC_ADDRESS=""
TXC_RPC_USER=""
TXC_RPC_PASSWORD=""

# Firebase Cloud Messaging service-account JSON (single line, server-only)
FCM_SERVICE_ACCOUNT_JSON=""
